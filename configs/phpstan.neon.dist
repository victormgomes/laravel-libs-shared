parameters:
    level: 5
    paths:
        - src
        - config
        - database
    ignoreErrors:
        -
            message: "#^Called 'env' outside of the config directory#"
            path: config/query-engine.php
        -
            message: "#^Trait .*\\\\HasQueryEngineRules is used zero times and is not analysed\\.$#"
            path: src/Traits/HasQueryEngineRules.php
    tmpDir: build/phpstan
